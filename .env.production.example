# =============================================================================
# EasyPrint - PRODUCTION Environment
# =============================================================================
# WARNING: Never commit this file with real credentials!
# =============================================================================

APP_NAME=easyPrint
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.easyprint.com
FRONTEND_URL=https://easyprint.vercel.app
APP_ADMIN_PASSWORD=
GA_MEASUREMENT_ID=

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=easyprint
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

LOG_CHANNEL=stack
LOG_LEVEL=error
SENTRY_LARAVEL_DSN=

CORS_ALLOWED_ORIGINS=https://easyprint.vercel.app
SANCTUM_STATEFUL_DOMAINS=easyprint.vercel.app

VITE_APP_NAME="${APP_NAME}"
