# =============================================================================
# EasyPrint - Production Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment:
#   cp .env.example .env
# =============================================================================

# -- Application --
APP_NAME=easyPrint
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.easyprint.com
FRONTEND_URL=https://easyprint.vercel.app

# -- Locale --
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -- Maintenance --
APP_MAINTENANCE_DRIVER=file

# -- Admin --
# Generate with: php -r "echo password_hash('your-password', PASSWORD_BCRYPT);"
APP_ADMIN_PASSWORD=

# -- Google Analytics --
GA_MEASUREMENT_ID=

# -- Bcrypt --
BCRYPT_ROUNDS=12

# -- Database (MySQL) --
# Railway provides: MYSQL_URL, MYSQL_HOST, MYSQL_PORT, MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -- Session (Database) --
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# -- Cache (Database) --
CACHE_STORE=database

# -- Queue (Database) --
QUEUE_CONNECTION=database

# -- Broadcasting --
BROADCAST_CONNECTION=log

# -- File Storage --
FILESYSTEM_DISK=public
# For Cloudinary:
# FILESYSTEM_DISK=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# For Cloudflare R2 (S3-compatible):
# FILESYSTEM_DISK=r2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=easyprint-uploads
# AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# AWS_URL=https://<bucket>.<account>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# -- Mail --
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@easyprint.com"
MAIL_FROM_NAME="${APP_NAME}"

# -- Redis (optional, for high performance) --
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -- Logging --
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# -- Sentry (error monitoring) --
SENTRY_LARAVEL_DSN=

# -- CORS --
CORS_ALLOWED_ORIGINS=https://easyprint.vercel.app,http://localhost:5173

# -- Sanctum --
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# -- Vite --
VITE_APP_NAME="${APP_NAME}"
